<div class="mx-auto w-full max-w-md">
  <div class="flex flex-wrap justify-between items-center min-h-12 sm:min-h-16 mb-4">
    <h1 class="text-primary font-bold text-4xl"><%= page_title!('Nouvel utilisateur') %></h1>
  </div>

  <%= form_for(@user, url: { controller: 'admin', action: 'create_new_user_do' }, method: :post) do |f| %>
    <%= render partial: 'partials/errors', locals: { record: @user } %>
    <div class="flex flex-col gap-4">
      <div class="form-control">
        <%= f.label :nom, "Nom *" %>
        <%= f.text_field :nom, class: 'input input-bordered input-sm w-full' %>
      </div>

      <div class="form-control">
        <%= f.label :prénom, "Prénom *" %>
        <%= f.text_field :prénom, class: 'input input-bordered input-sm w-full' %>
      </div>

      <div class="form-control">
        <%= f.label :email, "Email *" %>
        <%= f.email_field :email, class: 'input input-bordered input-sm w-full' %>
      </div>

      <div class="form-control">
        <%= f.label :mobile %>
        <%= f.text_field :mobile, class: 'input input-bordered input-sm w-full' %>
      </div>

      <div class="form-control">
        <%= f.label :role, "Rôle" %>
        <%= f.select :role, options_for_select(User.roles.keys, @user.role), {}, class: 'select select-bordered select-sm w-full' %>
      </div>
      
      <%= f.submit class: "btn btn-primary text-white mt-4", 'data-turbo': false %>
    </div>
  <% end %>

  <%= link_to "Annuler", users_path, class: "btn mt-4" %>
</div>
