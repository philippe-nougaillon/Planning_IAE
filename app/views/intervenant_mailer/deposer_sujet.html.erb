<% content_for :masquer_entete, true %>

<p style="margin-bottom: 0.5rem">
    Bonjour <%= @sujet.cour.formation.user&.prénom_et_nom %>,
    <br><br>
    L'intervenant <%= @sujet.cour.intervenant_binome&.nom_prenom %> a déposé son sujet pour l'examen du <b><%= l(@sujet.cour.debut.to_date, format: :long) %> à <%= l @sujet.cour.debut, format: :heures_log %> - <%= @sujet.cour.nom_ou_ue %> </b>.
    <br>
</p>

<p style="margin-bottom: 0.5rem">
    Vous pouvez valider ou rejeter le sujet d'examen en <%= link_to 'cliquant ici', url_for(sujet_url(@sujet)) %>.
</p>