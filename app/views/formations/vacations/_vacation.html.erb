<% saved = local_assigns.fetch(:saved, false) %>
<%= turbo_frame_tag dom_id(vacation) do %>
  <% if vacation.titre.present? %>
    <%# Vacation « legacy » (antérieure à 2024) : lecture seule, comportement initial conservé %>
    <div class="flex flex-wrap shadow pb-4 mb-4 rounded items-end bg-base-200/50">
      <div class="sm:w-full px-4 pt-3 text-xs text-gray-400 italic">
        <%= fa_icon 'lock' %> Vacation antérieure à 2024 (lecture seule)
      </div>
      <div class="sm:w-2/12 px-4"><span class="text-xs text-gray-400">Date</span><br><%= l vacation.date if vacation.date %></div>
      <div class="sm:w-3/12 px-4"><span class="text-xs text-gray-400">Intervenant</span><br><%= vacation.intervenant&.nom_prenom_status %></div>
      <div class="sm:w-3/12 px-4"><span class="text-xs text-gray-400">Activité antérieure</span><br><%= vacation.titre %></div>
      <div class="sm:w-2/12 px-4"><span class="text-xs text-gray-400">Forfait HTD</span><br><%= "#{vacation.forfaithtd} h" if vacation.forfaithtd %></div>
      <div class="sm:w-1/12 px-4"><span class="text-xs text-gray-400">Qté</span><br><%= vacation.qte %></div>
      <% if vacation.commentaires.present? %>
        <div class="sm:w-full px-4 mt-2"><span class="text-xs text-gray-400">Commentaires</span><br><%= vacation.commentaires %></div>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-wrap shadow pb-4 mb-4 rounded items-end <%= 'border-2 border-error' if vacation.errors.any? %>">
      <% if vacation.errors.any? %>
        <div class="sm:w-full px-4 pt-3 text-error text-sm">
          <ul class="list-disc list-inside">
            <% vacation.errors.each do |error| %>
              <li><%= error.full_message.html_safe %></li>
            <% end %>
          </ul>
        </div>
      <% elsif saved %>
        <div class="sm:w-full px-4 pt-3 text-success text-sm font-semibold">
          <%= fa_icon 'check' %> Vacation enregistrée
        </div>
      <% end %>

      <%= form_with model: vacation, url: formation_vacation_path(@formation, vacation), method: :patch, class: "contents" do |f| %>
        <%= render "formations/vacations/fields", f: f %>
        <div class="px-4 self-end">
          <%= f.submit "Enregistrer", class: "btn btn-sm btn-primary text-white w-full" %>
        </div>
      <% end %>

      <div class="sm:w-1/12 px-4 self-end mt-4">
        <%= button_to formation_vacation_path(@formation, vacation),
                      method: :delete,
                      class: "btn btn-sm btn-ghost text-error w-full",
                      form: { data: { turbo_confirm: "Supprimer définitivement cette vacation ?" } } do %>
          <%= fa_icon 'trash' %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
